# Copy this file to .env and replace the placeholder values.
# Do not commit .env (it is gitignored).

# AWS credentials (required for Bedrock custom YAML transform)
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=us-east-1

# Optional: Bedrock model override (default: anthropic.claude-sonnet-4-20250514-v1:0)
# BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Optional: use JSON file store (default: true)
# USE_JSON_STORE=true
